{
  "$schema": "http://schemastore.org",
  "name": "Advanced WPF Solution",
  "shortName": "advanced.wpf",
  "author": "SA",
  "classifications": [ "WPF" ],
  "identity": "SAKryukov.MoonLab.ProjectTemplate.CSharp",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "copyright": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "Copyright © 2026 Sergey A Kryukov",
      "description": "Solution copyright",
      "replaces": "copyright-long-unique-name-not-to-be-repeated"
    },
    "creator-company": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "SA",
      "description": "Creator Company",
      "replaces": "creator-company-long-unique-name-not-to-be-repeated"
    },
    "root-namespace": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "SA",
      "description": "Root namespace for the main application",
      "replaces": "root-namespace-long-unique-name-not-to-be-repeated"
    }
  },  
  "sourceName": "main-application-name-long-unique-name-not-to-be-repeated"
}
